# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=EliteVault

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...   # server-only, NEVER expose

# ─── AI Provider ────────────────────────────────────────────────────────────
# Which provider drives the Analyzer + agents. Default: gemini (free tier).
#   gemini    — free, no card required, get key at https://aistudio.google.com/apikey
#   anthropic — Claude (premium, $5 minimum on console.anthropic.com)
AI_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_MODEL_FAST=gemini-2.5-flash

# Anthropic (only required if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Price IDs (created by `npm run stripe:seed` or manually in Stripe Dashboard)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_SCALE_MONTHLY=price_...
STRIPE_PRICE_SCALE_YEARLY=price_...

# ─── Inngest ────────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Optional: site scraping (used by analyzer) ─────────────────────────────
# Either provide a Browserless / ScrapingBee / ScreenshotOne key, OR the
# analyzer will fall back to Anthropic vision on a URL fetch only.
SCREENSHOTONE_ACCESS_KEY=

# ─── Analytics (optional but recommended) ───────────────────────────────────
# Vercel Analytics + Speed Insights need NO env var — they auto-enable once
# the project is deployed to Vercel and the Analytics tab is turned on in
# the dashboard.
#
# PostHog: product analytics, funnels, session replay. Sign up at
# https://posthog.com (free 1M events/mo). Then paste the project API key
# here. Without it the provider no-ops and nothing is sent.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
