# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=EliteVault

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...   # server-only, NEVER expose

# ─── AI Provider ────────────────────────────────────────────────────────────
# Which provider drives the Analyzer + agents. Default: gemini (free tier).
#   gemini    — free, no card required, get key at https://aistudio.google.com/apikey
#   anthropic — Claude (premium, $5 minimum on console.anthropic.com)
AI_PROVIDER=gemini

# Gemini — these defaults are the BEST models still on Google's FREE tier.
# MODEL = paid audits, MODEL_FAST = free audits + automatic fallback rung.
# NOTE: free-tier limits are per PROJECT, not per key — extra keys below only
# add quota if they come from DIFFERENT Google projects/accounts.
# With billing enabled, upgrade MODEL to gemini-2.5-pro / gemini-3.1-pro.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MODEL_FAST=gemini-3.1-flash-lite

# Anthropic (only required if AI_PROVIDER=anthropic, or as analyzer paid tier)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5          # workhorse; claude-opus-4-8 for max quality
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MAX_RETRIES=4                  # SDK retries on 429/529/5xx w/ backoff

# ─── Analyzer provider routing (optional) ───────────────────────────────────
# Run the free/fast audit and the paid audit on DIFFERENT providers. Unset =
# both fall back to AI_PROVIDER (identical to legacy single-provider behaviour).
# Recommended once an Anthropic key is funded: paid → Claude, free → Gemini Flash.
#   ANALYZER_PROVIDER_PAID=anthropic
#   ANALYZER_PROVIDER_FAST=gemini
# On a hard failure, retry once on the OTHER provider (only if its key is set).
# Off by default so it never causes surprise spend.
#   ANALYZER_CROSS_FALLBACK=1

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Price IDs (created by `npm run stripe:seed` or manually in Stripe Dashboard)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_SCALE_MONTHLY=price_...
STRIPE_PRICE_SCALE_YEARLY=price_...

# ─── Inngest ────────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Resend (transactional email — weekly monitoring digest) ────────────────
# Reuse the same Resend account/domain already verified for Supabase SMTP.
# Create an API key at resend.com → API Keys. RESEND_FROM must be a verified
# sender on your domain. Without these the digest send no-ops (job still runs).
RESEND_API_KEY=
RESEND_FROM=EliteVault <login@elitevaultapp.com>

# ─── Optional: site scraping (used by analyzer) ─────────────────────────────
# Either provide a Browserless / ScrapingBee / ScreenshotOne key, OR the
# analyzer will fall back to Anthropic vision on a URL fetch only.
SCREENSHOTONE_ACCESS_KEY=

# ─── Analytics (optional but recommended) ───────────────────────────────────
# Vercel Analytics + Speed Insights need NO env var — they auto-enable once
# the project is deployed to Vercel and the Analytics tab is turned on in
# the dashboard.
#
# PostHog: product analytics, funnels, session replay. Sign up at
# https://posthog.com (free 1M events/mo). Then paste the project API key
# here. Without it the provider no-ops and nothing is sent.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Comma-separated list of emails to EXCLUDE from analytics. Use this so
# your own dev/testing activity never inflates the funnel. When a user
# with one of these emails visits, the analytics gate suppresses ALL
# tracking (Vercel + PostHog + Speed Insights) AND drops a localStorage
# flag so future visits on the same browser stay silent even when
# logged out.
#
# Add the owner email + any test accounts. Example:
#   INTERNAL_EMAILS=you@gmail.com,test-pro@elitevault.local
#
# To exclude a device that never signs in (incognito QA, family laptop)
# visit /internal-opt-out on that browser once — same effect.
INTERNAL_EMAILS=

# ─── Panel del dueño (/app/owner) ───────────────────────────────────────────
# Emails con acceso al panel privado de métricas (coma-separados). Si está
# vacío, NADIE entra (fail-closed). Si no se define, se usa INTERNAL_EMAILS.
ADMIN_EMAILS=
# PostHog server-side (tráfico real en el panel: en vivo, dispositivos, fuentes).
# Personal API Key: PostHog → Settings → Personal API Keys (NO la NEXT_PUBLIC_*).
POSTHOG_API_KEY=
# Id numérico del proyecto en PostHog (Settings → Project).
POSTHOG_PROJECT_ID=
# Opcional: host de la API. Por defecto deriva de NEXT_PUBLIC_POSTHOG_HOST
# (us.i.posthog.com → us.posthog.com). EU: https://eu.posthog.com
POSTHOG_API_HOST=

# Panel del dueño: fecha de RESET de estadísticas (ISO). El panel solo cuenta
# datos a partir de esta fecha (no borra nada). Ej: 2026-06-20T00:00:00Z
OWNER_METRICS_RESET_AT=
